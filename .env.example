# ==============================================================================
# AI Career Copilot - Global Environment Configuration Example
# Copy this file to .env and fill in the values before running docker-compose
# ==============================================================================

# --- Backend Core Configuration (Node.js) ---
NODE_ENV=production
PORT=5000
JWT_SECRET=your_secure_jwt_secret_here
JWT_EXPIRE=30d

# Database & Cache (In Docker, these use the service names 'mongo' and 'redis')
MONGO_URI=mongodb://mongo:27017/pathforge
REDIS_URL=redis://redis:6379

# Internal Service Communication
AI_ENGINE_URL=http://ai-engine:8000

# --- AI Engine Configuration (Python FastAPI) ---
AI_PROVIDER=gemini  # Options: gemini, openai, claude
LOG_LEVEL=INFO

# Provider API Keys
GEMINI_API_KEY=your_gemini_api_key_here
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Model Overrides (Optional)
# GEMINI_MODEL=models/gemini-2.5-flash
# OPENAI_MODEL=gpt-4-turbo-preview
# CLAUDE_MODEL=claude-3-sonnet-20240229

# --- Frontend Configuration (Vite) ---
# Note: These must be prefixed with VITE_ for the frontend to pick them up
VITE_API_BASE_URL=http://localhost:5000/api
VITE_BACKEND_URL=http://localhost:5000
